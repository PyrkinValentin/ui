{
	"name": "@cora-ui/monorepo",
	"version": "1.1.5",
	"private": true,
	"workspaces": [
		"packages/*"
	],
	"overrides": {
		"react": "^19.0.0",
		"react-dom": "^19.0.0"
	},
	"devDependencies": {
		"@types/node": "^26.1.0",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"tailwindcss": "^4.0.0",
		"tsup": "^8.5.1",
		"esbuild-plugin-copy": "^2.1.1",
		"typescript": "^6.0.3"
	},
	"scripts": {
		"build": "npm run build --workspaces --if-present",
		"release:version": "npm version patch --workspaces --include-workspace-root --no-git-tag-version",
		"release": "npm run build && npm run release:version && git add . && git commit -m \"chore(release): bump version\" && npm publish --workspace=@cora-ui/react && git push origin main && git push origin --tags"
	},
	"engines": {
		"node": ">=22.0.0"
	},
	"packageManager": "npm@11.8.0"
}
