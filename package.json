{
	"name": "@cora-ui/monorepo",
	"version": "1.0.29",
	"private": true,
	"workspaces": [
		"packages/*"
	],
	"overrides": {
		"react": "^19.0.0",
		"react-dom": "^19.0.0"
	},
	"devDependencies": {
		"@types/react": "^19.0.0",
		"@types/react-dom": "^19.0.0",
		"tsup": "^8.0.0",
		"tailwindcss": "^4.0.0",
		"typescript": "^6.0.3"
	},
	"scripts": {
		"build": "npm run build --workspaces --if-present",
		"version:bump": "npm version patch --workspaces --include-workspace-root --no-git-tag-version",
		"release": "npm publish --workspace=@cora-ui/react && git push origin main --follow-tags"
	},
	"engines": {
		"node": ">=22.0.0"
	},
	"packageManager": "npm@11.8.0"
}
