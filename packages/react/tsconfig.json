{
	"compilerOptions": {
		"target": "ES2022",
		"ignoreDeprecations": "6.0",
		"lib": [
			"dom",
			"dom.iterable",
			"esnext"
		],
		"allowJs": true,
		"skipLibCheck": true,
		"strict": true,
		"noEmit": true,
		"declaration": true,
		"emitDeclarationOnly": true,
		"esModuleInterop": true,
		"module": "esnext",
		"moduleResolution": "bundler",
		"resolveJsonModule": true,
		"isolatedModules": true,
		"jsx": "react-jsx",
		"incremental": false
	},
	"include": [
		"src/**/*.ts",
		"src/**/*.tsx",
		"index.ts",
		"tsup.config.ts"
	],
	"exclude": [
		"node_modules",
		"build"
	]
}