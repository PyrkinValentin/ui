{
	"name": "@cora-ui/react",
	"version": "1.0.7",
	"author": "Cora",
	"description": "Next-generation, high-performance React 19 UI component kit built on Base UI and Tailwind CSS v4 with native accessibility and zero runtime overhead.",
	"license": "MIT",
	"type": "module",
	"keywords": [
		"react",
		"react ui",
		"react components",
		"next",
		"cora-ui",
		"a11y"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/PyrkinValentin/cora-ui.git"
	},
	"bugs": {
		"url": "https://github.com/PyrkinValentin/cora-ui/issues"
	},
	"homepage": "https://cora-ui.com",
	"main": "./build/index.js",
	"types": "./build/index.d.ts",
	"exports": {
		".": {
			"import": "./build/index.js",
			"types": "./build/index.d.ts"
		},
		"./styles": "./build/styles/styles.css",
		"./hooks": "./build/hooks/index.js"
	},
	"files": [
		"build"
	],
	"scripts": {
		"build": "tsup",
		"prepublishOnly": "npm run build"
	},
	"peerDependencies": {
		"react": ">=19.0.0",
		"react-dom": ">=19.0.0",
		"tailwindcss": ">=4.0.0"
	},
	"dependencies": {
		"@base-ui/react": "^1.6.0",
		"lucide-react": "^1.22.0"
	},
	"devDependencies": {
		"@tailwindcss/postcss": ">=4.0.0",
		"@types/react": ">=19.0.0",
		"@types/react-dom": ">=19.0.0",
		"postcss": ">=8.4.0",
		"tsup": ">=8.0.0",
		"tailwindcss": ">=4.0.0",
		"typescript": ">=6.0.0"
	},
	"sideEffects": false,
	"publishConfig": {
		"access": "public",
		"directory": "build"
	},
	"engines": {
		"node": ">=22.0.0"
	}
}
