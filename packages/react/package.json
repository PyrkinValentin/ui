{
	"name": "@cora-ui/react",
	"version": "1.0.9",
	"author": "Cora",
	"description": "Next-generation, high-performance React 19 UI component kit built on Base UI and Tailwind CSS v4 with native accessibility and zero runtime overhead.",
	"license": "MIT",
	"type": "module",
	"keywords": [
		"react",
		"react19",
		"nextjs",
		"cora-ui",
		"coraui",
		"base-ui",
		"tailwind",
		"tailwindcss",
		"tailwind-v4",
		"ui-kit",
		"design-system",
		"components",
		"react-components",
		"headless-ui",
		"accessibility",
		"a11y",
		"wai-aria",
		"wcag",
		"mcp-server",
		"high-performance"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/PyrkinValentin/cora-ui.git"
	},
	"bugs": {
		"url": "https://github.com/PyrkinValentin/cora-ui/issues"
	},
	"homepage": "https://cora-ui.com",
	"main": "./build/index.js",
	"types": "./build/index.d.ts",
	"exports": {
		".": {
			"import": "./build/index.js",
			"types": "./build/index.d.ts"
		},
		"./hooks": {
			"import": "./build/hooks/index.js",
			"types": "./build/hooks/index.d.ts"
		},
		"./utils": {
			"import": "./build/utils/index.js",
			"types": "./build/utils/index.d.ts"
		},
		"./styles": "./build/styles/styles.css",
		"./package.json": "./package.json"
	},
	"files": [
		"build"
	],
	"scripts": {
		"build": "tsup && tsup --config tsup.utils.config.ts && tailwindcss -i src/styles/styles.css -o build/styles/styles.css --minify",
		"prepublishOnly": "npm run build"
	},
	"peerDependencies": {
		"react": ">=19.0.0",
		"react-dom": ">=19.0.0"
	},
	"dependencies": {
		"@base-ui/react": "^1.6.0",
		"lucide-react": "^1.22.0"
	},
	"devDependencies": {
		"@tailwindcss/cli": ">=4.0.0",
		"@types/react": ">=19.0.0",
		"@types/react-dom": ">=19.0.0",
		"tailwindcss": ">=4.0.0",
		"tsup": ">=8.0.0",
		"typescript": ">=6.0.0"
	},
	"sideEffects": false,
	"publishConfig": {
		"access": "public",
		"directory": "build"
	},
	"engines": {
		"node": ">=22.0.0"
	}
}
